{
  "manifest_version": 3,
  "name": "WhatSite",
  "short_name": "WhatSite",
  "version": "1.0.0",
  "description": "Per-tab visibility into cookies, third-party connections, IP geolocation and live threat scores, with optional auto-blocking.",
  "homepage_url": "https://cloudsecurity.global",
  "permissions": [
    "cookies",
    "webRequest",
    "webNavigation",
    "alarms",
    "storage",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/inspector.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "WhatSite — Cookie & Connection Tracker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
